rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'poorvith519@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid is string &&
               data.email is string;
      }
      
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'track', 'targetExam', 'updatedAt']);
      allow delete: if isAdmin();

      // Attempts subcollection
      match /attempts/{attemptId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Questions Bank
    match /questions/{questionId} {
      function isValidQuestion(data) {
        return data.keys().hasAll(['id', 'questionText', 'correctAnswer']) &&
               data.id is string &&
               data.questionText is string &&
               data.correctAnswer is string;
      }

      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidQuestion(request.resource.data);
    }

    // Admin List (System Managed)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }
  }
}
